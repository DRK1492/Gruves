# Supabase project credentials — find these in your Supabase dashboard under Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# The public URL of this app — used for auth redirect URLs (e.g. magic links, OAuth callbacks)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
